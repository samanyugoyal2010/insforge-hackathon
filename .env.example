# Copy to `.env.local` for local dev (Next.js loads it automatically).
# On Render: set the same keys in the service Environment (no file).

# --- App URL (Stripe success/cancel fallbacks; use your real public URL in prod) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (browser + server) ---
# Project URL from Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Supabase Dashboard → Settings → API → "Publishable" key (or legacy anon key name in dashboard)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# Optional legacy: health check accepts this instead of PUBLISHABLE_KEY
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: Settings → API → service_role (never expose to the client).
# Optional for local dev if you apply supabase/migrations/*_node0_ar_handoff_rpc.sql (AR QR uses RPC + publishable key).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ0YnFzcXBvaWxtenB0c3duZXFmIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NTIwMzM3NSwiZXhwIjoyMDkwNzc5Mzc1fQ.OGWB3hWsDpp9vREfwah2-9eHGyXrCPJdsfcxQceYFe4

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# Optional model overrides (defaults shown in code if unset)
# OPENAI_BEST_MODEL=o3
# OPENAI_CAD_MODEL=
# OPENAI_FIRMWARE_MODEL=o3
# NODE0_PCBFLOW_MODEL=gpt-4o-mini
# Optional: separate model for pre-codegen assembly stage planning (defaults to NODE0_PCBFLOW_MODEL)
# NODE0_PCBFLOW_STAGE_PLAN_MODEL=gpt-4o-mini

# --- Stripe (omit if you are not using checkout) ---
# Use test mode locally: keys start with sk_test_ (Dashboard → Developers → API keys).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: legacy fixed-price checkout used STRIPE_PRICE_ID; dynamic checkout does not require it.

# Optional fab quote tuning (USD cents; see src/lib/fab-quote.ts)
# PCB subtotal = area(cm²) × rate × qty; clamped to min/max for the whole PCB line (not × qty).
# FAB_PCB_CENTS_PER_CM2=14
# FAB_PCB_MIN_CENTS=2200
# FAB_PCB_MAX_CENTS=250000
# CAD subtotal = enclosure volume(dm³) × rate × qty; clamped once for the CAD line.
# FAB_CAD_CENTS_PER_DM3=1400
# FAB_CAD_MIN_CENTS=900
# FAB_CAD_MAX_CENTS=80000
# FAB_PLATFORM_FEE_CENTS=500

# --- Circuitron / KiCad pipeline (optional) ---
# MCP base URL only (no /sse suffix); defaults to http://localhost:8051
# CIRCUITRON_MCP_URL=http://localhost:8051
# MCP_URL=http://localhost:8051

# Skip MCP reachability check (demo / broken MCP only)
# CIRCUITRON_SKIP_MCP_CHECK=1

# Custom Circuitron binary or Python (advanced)
# CIRCUITRON_BIN=
# PYTHON=python3

# Subprocess timeouts (ms)
# CIRCUITRON_TIMEOUT_MS=1800000
# NODE0_PCBFLOW_TIMEOUT_MS=120000

# Override KiCad Docker image passed into Circuitron env
# CIRCUITRON_KICAD_IMAGE=ghcr.io/shaurya-sethi/circuitron-kicad:latest

# Logfire / observability for Circuitron child env (optional)
# LOGFIRE_SEND_TO_LOGFIRE=
# LOGFIRE_BASE_URL=
# LOGFIRE_TOKEN=
# LOGFIRE_PROJECT_NAME=

# --- PCBFlow subprocess (Docker / custom Python path) ---
# In the official Dockerfile this is set for you; override locally if needed
# NODE0_PYTHON=/path/to/python3

# --- Next / Node (usually do not set locally) ---
# NODE_ENV is set by Next.js
# NEXT_TELEMETRY_DISABLED=1
